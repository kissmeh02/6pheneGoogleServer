# =============================================================================
# 6phene Server Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env files with real secrets to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=production
DEBUG=false

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite+aiosqlite:///./graphene_composite.db

# -----------------------------------------------------------------------------
# Gemini AI Chat Widget
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_PROXY_PORT=8090

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
VITE_API_URL=/api

# -----------------------------------------------------------------------------
# SSL / Let's Encrypt
# -----------------------------------------------------------------------------
SSL_DOMAIN=6phene.com
SSL_EMAIL=kavankissoon@gmail.com

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
